# ---------------------------------------------------------------------------
# Servidor
# ---------------------------------------------------------------------------
PORT=4000
PUBLIC_BASE_URL=http://localhost:4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=voxia

# ---------------------------------------------------------------------------
# OpenAI Realtime
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE_DEFAULT=marin

# ---------------------------------------------------------------------------
# Proveedores de telefonia habilitados (separados por coma)
# Valores validos: twilio_realtime, openai_native_sip
# Habilita los dos si vas a tener clientes de ambos tipos en esta misma
# instancia -- el proveedor real de cada cliente se elige por organizacion,
# no aqui (ver POST /api/v1/organizations).
# ---------------------------------------------------------------------------
TELEPHONY_PROVIDERS=twilio_realtime,openai_native_sip

# ---------------------------------------------------------------------------
# Twilio (necesario solo si twilio_realtime esta habilitado)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+10000000000

# ---------------------------------------------------------------------------
# OpenAI SIP nativo (necesario solo si openai_native_sip esta habilitado)
# Verifica el nombre/forma exacta de estos valores contra la documentacion
# vigente de OpenAI al momento de activar este proveedor en produccion.
# ---------------------------------------------------------------------------
OPENAI_SIP_WEBHOOK_SECRET=changeme

# ---------------------------------------------------------------------------
# Autenticacion
# ---------------------------------------------------------------------------
# Genera uno real con: openssl rand -hex 32
JWT_SECRET=changeme
JWT_EXPIRES_IN=12h

# ---------------------------------------------------------------------------
# Usuario admin sembrado al correr `npm run db:init` (solo si no existe ya
# un usuario con este email). Es la cuenta con la que entras la primera vez.
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@voxia.com
SEED_ADMIN_PASSWORD=changeme123
