# ---------------------------------------------------------------------------
# Servidor
# ---------------------------------------------------------------------------
PORT=4000
PUBLIC_BASE_URL=http://localhost:4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=voxia

# ---------------------------------------------------------------------------
# OpenAI Realtime
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE_DEFAULT=marin

# ---------------------------------------------------------------------------
# Proveedores de telefonia habilitados (separados por coma)
# Valores validos: twilio_realtime, openai_native_sip, elevenlabs_twilio,
# hume_evi_twilio
# Habilita los que vayas a tener clientes de ese tipo en esta misma
# instancia -- el proveedor real de cada cliente se elige por organizacion,
# no aqui (ver POST /api/v1/organizations). elevenlabs_twilio y
# hume_evi_twilio son proveedores de PRUEBA (voz/agente de ElevenLabs o
# Hume en vez de OpenAI Realtime, originan la llamada igual via Twilio) --
# ver ELEVENLABS_API_KEY/AGENT_ID y HUME_API_KEY/SECRET_KEY/CONFIG_ID.
# ---------------------------------------------------------------------------
TELEPHONY_PROVIDERS=twilio_realtime,openai_native_sip

# ---------------------------------------------------------------------------
# Twilio (necesario solo si twilio_realtime esta habilitado)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+10000000000

# ---------------------------------------------------------------------------
# OpenAI SIP nativo (necesario solo si openai_native_sip esta habilitado)
# Verifica el nombre/forma exacta de estos valores contra la documentacion
# vigente de OpenAI al momento de activar este proveedor en produccion.
# ---------------------------------------------------------------------------
OPENAI_SIP_WEBHOOK_SECRET=changeme

# ---------------------------------------------------------------------------
# ElevenLabs (proveedor de PRUEBA, necesario solo si elevenlabs_twilio esta
# habilitado). El agente (personalidad/guion) se configura en el dashboard
# de ElevenLabs, no aqui -- ELEVENLABS_AGENT_ID solo identifica cual usar.
# ---------------------------------------------------------------------------
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Hume EVI (proveedor de PRUEBA, necesario solo si hume_evi_twilio esta
# habilitado). El agente (personalidad/voz) se configura en el dashboard de
# Hume, no aqui -- HUME_CONFIG_ID solo identifica cual usar. HUME_SECRET_KEY
# no se usa en el flujo actual (autenticacion del WebSocket via api_key
# directo), se guarda por si mas adelante hace falta el flujo de access_token.
# ---------------------------------------------------------------------------
HUME_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUME_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUME_CONFIG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Autenticacion
# ---------------------------------------------------------------------------
# Genera uno real con: openssl rand -hex 32
JWT_SECRET=changeme
JWT_EXPIRES_IN=12h

# ---------------------------------------------------------------------------
# Usuario admin sembrado al correr `npm run db:init` (solo si no existe ya
# un usuario con este email). Es la cuenta con la que entras la primera vez.
# ---------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@voxia.com
SEED_ADMIN_PASSWORD=changeme123
